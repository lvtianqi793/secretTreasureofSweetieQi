# MCP SSE 端点（容器内自引用，宿主机开发时改为 http://localhost:8000/mcp/sse）
MCP_SSE_URL=http://127.0.0.1:8000/mcp/sse
MCP_HTTP_TIMEOUT=30.0

# 最大工具调用轮次（防死循环）
MAX_AGENT_STEPS=6

# SSE 预览长度限制（字符数）
PREVIEW_ARGS_LIMIT=200
PREVIEW_RESULT_LIMIT=400

# Ollama 调用超时（秒）
OLLAMA_TIMEOUT=300

# 容器内导出目录路径（与 compose.yaml 中的 target 一致）
EXPORTS_DIR=/app/exports

# 导出目录 URL 路径（FastAPI 挂载的静态路径）
EXPORTS_URL_PATH=/exports

# 宿主机导出目录路径（用于 bind mount）
# 默认使用相对路径 ./exports，生产环境可改为绝对路径如 /data/exports
EXPORTS_HOST_DIR=./exports