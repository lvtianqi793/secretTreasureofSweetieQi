# ==========================================
# Git 版本控制（不要进镜像）
# ==========================================
.git
.gitignore

# ==========================================
# Python（本地依赖不要复制进镜像）
# ==========================================
__pycache__/
venv/
.venv/
env/
*.pyc
*.pyo
*.pyd
*.log
.env
.env.*
.idea/
.vscode/

# ==========================================
# Vue / Node（node_modules 不要进镜像）
# ==========================================
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 系统文件
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Docker 自身
# ==========================================
docker-compose.override.yml
