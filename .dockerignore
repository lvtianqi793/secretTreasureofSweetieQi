# ==========================================
# Git 版本控制（绝对不要进镜像）
# ==========================================
.git
.gitignore
.github/

# ==========================================
# Python（本地依赖、缓存、环境、IDE 都排除）
# ==========================================
__pycache__/
venv/
.venv/
env/
ENV/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.so
.Python
.pytest_cache/
.mypy_cache/
.tox/
.nox/
.coverage
htmlcov/
local_settings.py
*.log

# 敏感环境变量（绝对禁止进镜像！）
.env
.env.*

# IDE 配置（无关）
.idea/
.vscode/

# ==========================================
# Vue / Node（前端依赖、构建产物、日志）
# ==========================================
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 系统垃圾文件
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Docker 本地配置
# ==========================================
docker-compose.override.yml
Dockerfile.dev
docker-compose.dev.yml

# ==========================================
# 其他无用文件（减小镜像体积）
# ==========================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~# ==========================================
